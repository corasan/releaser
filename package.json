{
  "name": "releaser",
  "version": "0.1.1",
  "description": "Smart release CLI for npm packages, Expo apps, Tauri apps, and macOS apps",
  "type": "module",
  "bin": {
    "releaser": "./src/index.tsx"
  },
  "scripts": {
    "dev": "bun run src/index.tsx",
    "build": "bun build src/index.tsx --outdir dist --target bun",
    "compile": "bun build src/index.tsx --compile --outfile releaser"
  },
  "dependencies": {
    "ink": "^5.1.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1",
    "@anthropic-ai/claude-code": "^0.2.26"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.12",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "release",
    "cli",
    "npm",
    "expo",
    "tauri",
    "macos"
  ],
  "license": "MIT"
}
