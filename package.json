{
  "name": "releaser",
  "version": "0.1.0",
  "description": "Smart release CLI for npm packages, Expo apps, Tauri apps, and macOS apps",
  "type": "module",
  "bin": {
    "releaser": "./src/index.tsx"
  },
  "scripts": {
    "dev": "bun run src/index.tsx",
    "build": "bun build src/index.tsx --outdir dist --target bun",
    "compile": "bun build src/index.tsx --compile --outfile releaser",
    "install-local": "bun run compile && mv releaser /usr/local/bin/releaser",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format .",
    "format:write": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "bun test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "ink": "^5.1.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/bun": "latest",
    "@types/react": "^18.3.12",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "release",
    "cli",
    "npm",
    "expo",
    "tauri",
    "macos"
  ],
  "license": "MIT"
}
